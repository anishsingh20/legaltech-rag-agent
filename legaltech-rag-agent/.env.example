# Copy to .env and fill in values. Never commit .env to Git.
#
# Tip: after running scripts/03_create_knowledge_base.py, copy values from
# ../config.env (KNOWLEDGE_BASE_ID, DIGITALOCEAN_API_TOKEN, MODEL_ACCESS_KEY).

# Serverless Inference model access key
# Control Panel: INFERENCE -> Serverless Inference -> Model Access Keys
MODEL_ACCESS_KEY=your_model_access_key

# Personal access token with GenAI:read (retrieval/MCP) and genai deploy scopes
DIGITALOCEAN_API_TOKEN=your_personal_access_token

# Knowledge base UUID from Control Panel URL or API
KNOWLEDGE_BASE_ID=your_knowledge_base_uuid

# Optional tuning
INFERENCE_MODEL=anthropic-claude-sonnet-4.6
NUM_RESULTS=5
RETRIEVAL_ALPHA=0.5
