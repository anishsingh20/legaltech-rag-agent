# Copy this file to config.env and fill in values.
# Load before every script:  source config.env
#
# Never commit config.env to Git.

# ---------------------------------------------------------------------------
# Required: DigitalOcean personal access token
# Scopes: genai (create/read/update/delete) + GenAI:read (retrieve/MCP)
# Create at: https://cloud.digitalocean.com/account/api/tokens
# ---------------------------------------------------------------------------
export DIGITALOCEAN_API_TOKEN="your_personal_access_token"

# ---------------------------------------------------------------------------
# Required after Step 1 discover script OR from Control Panel
# Control Panel: Settings -> Projects -> copy project UUID
# ---------------------------------------------------------------------------
export DO_PROJECT_ID="your_project_uuid"

# ---------------------------------------------------------------------------
# Knowledge Base settings (defaults work for this tutorial lab)
# ---------------------------------------------------------------------------
export KB_NAME="legaltech-cases-kb"
export KB_REGION="tor1"

# All MiniLM L6 v2 (low cost lab default). Verified via DO MCP model search.
# Alternatives:
#   GTE Large EN v1.5 -> 22653204-79ed-11ef-bf8f-4e013e2ddde4
#   Bge M3            -> 78836a83-26d0-11f1-b074-4e013e2ddde4
export EMBEDDING_MODEL_UUID="22652c2a-79ed-11ef-bf8f-4e013e2ddde4"

# Default VPC for TOR1. Verified via DO MCP vpc-list.
export VPC_UUID="db9169a0-e935-4329-9add-3ee52359105a"

# Enable reranking for LegalTech precision (optional but recommended)
export KB_RERANKING_ENABLED="true"
export KB_RERANKING_MODEL="bge-reranker-v2-m3"

# ---------------------------------------------------------------------------
# Spaces settings (Step 2 upload)
# ---------------------------------------------------------------------------
export SPACES_REGION="tor1"
export SPACES_BUCKET="legaltech-casefiles-tutorial"
export SPACES_PREFIX="cases"

# Spaces S3 credentials (create in Control Panel or via spaces-key-create MCP tool)
export SPACES_ACCESS_KEY_ID="your_spaces_access_key"
export SPACES_SECRET_ACCESS_KEY="your_spaces_secret_key"

# ---------------------------------------------------------------------------
# Filled automatically by create_knowledge_base.py (do not set manually first)
# ---------------------------------------------------------------------------
# export KNOWLEDGE_BASE_ID=""

# ---------------------------------------------------------------------------
# Agent + inference (Steps 5-6)
# ---------------------------------------------------------------------------
# Prefer a dedicated Serverless model access key. If unavailable, a PAT with
# inference access can work as MODEL_ACCESS_KEY in lab setups.
export MODEL_ACCESS_KEY="your_serverless_model_access_key"
export INFERENCE_MODEL="anthropic-claude-sonnet-4"
export NUM_RESULTS="5"
export RETRIEVAL_ALPHA="0.5"

# Retrieval for hosted agent: rest (default, stable) or mcp (tool-demo / ADK local)
export RETRIEVAL_MODE="rest"
